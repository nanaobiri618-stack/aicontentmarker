generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Institution {
  id                 Int             @id @default(autoincrement())
  name               String
  slug               String          @unique @default("")
  industry           String
  description        String?         @db.Text
  website_url        String?
  logoBase64         String?         @map("logo_base64") @db.LongText
  documents          String?         @db.LongText
  verificationStatus String          @default("pending") @map("verification_status")
  verificationNote   String?         @map("verification_note") @db.Text
  subscription_tier  String          @default("free")
  paystackApiKey     String?         @map("paystack_api_key") @db.Text
  colorPrimary       String?         @default("#00D4FF") @map("color_primary")
  colorSecondary     String?         @default("#B026FF") @map("color_secondary")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  ownerId            Int?            @map("owner_id")
  owner              User?           @relation("InstitutionOwner", fields: [ownerId], references: [id])
  agentTasks         AgentTask[]
  brandGuides        BrandGuide[]
  contentSources     ContentSource[]
  generatedPosts     GeneratedPost[]
  generatedSite      GeneratedSite?
  products           Product[]
  socialHandles      SocialHandle[]
  users              User[]
  complaints         Complaint[]
  aiModels           AIModel[]

  @@map("institutions")
}

model BrandGuide {
  id                 Int         @id @default(autoincrement())
  institutionId      Int         @map("institution_id")
  toneVoice          String      @map("tone_voice")
  targetAudience     String      @map("target_audience")
  restrictedKeywords String      @default("[]") @map("restricted_keywords")
  colorPalette       String?     @map("color_palette")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  institution        Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId], map: "brand_guides_institution_id_fkey")
  @@map("brand_guides")
}

model ContentSource {
  id            Int         @id @default(autoincrement())
  institutionId Int         @map("institution_id")
  sourceType    String      @map("source_type")
  sourceUrl     String      @map("source_url")
  lastSynced    DateTime?   @map("last_synced")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  agentTasks    AgentTask[]
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId], map: "content_sources_institution_id_fkey")
  @@map("content_sources")
}

model AgentTask {
  id              Int             @id @default(autoincrement())
  institutionId   Int             @map("institution_id")
  contentSourceId Int?            @map("content_source_id")
  status          String          @default("queued")
  taskType        String          @map("task_type")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  contentSource   ContentSource?  @relation(fields: [contentSourceId], references: [id])
  institution     Institution     @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  generatedPosts  GeneratedPost[]

  @@index([contentSourceId], map: "agent_tasks_content_source_id_fkey")
  @@index([institutionId], map: "agent_tasks_institution_id_fkey")
  @@map("agent_tasks")
}

model User {
  id            Int          @id @default(autoincrement())
  email         String       @unique
  name          String?
  image         String?
  passwordHash  String?      @map("password_hash")
  institutionId      Int?            @map("institution_id")
  role               String          @default("owner")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  orders             Order[]
  institution        Institution?    @relation(fields: [institutionId], references: [id])
  ownedInstitutions  Institution[]   @relation("InstitutionOwner")
  complaints         Complaint[]

  @@index([institutionId], map: "users_institution_id_fkey")
  @@map("users")
}

model GeneratedPost {
  id            Int         @id @default(autoincrement())
  institutionId Int         @map("institution_id")
  agentTaskId   Int         @map("agent_task_id")
  platform      String
  contentText   String      @map("content_text")
  imageUrl      String?     @map("image_url")
  status        String      @default("pending")
  feedback      String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  agentTask     AgentTask   @relation(fields: [agentTaskId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([agentTaskId], map: "generated_posts_agent_task_id_fkey")
  @@index([institutionId], map: "generated_posts_institution_id_fkey")
  @@map("generated_posts")
}

model SocialHandle {
  id            Int         @id @default(autoincrement())
  institutionId Int         @map("institution_id")
  platform      String
  handle        String
  profileUrl    String?     @map("profile_url")
  createdAt     DateTime    @default(now()) @map("created_at")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId], map: "social_handles_institution_id_fkey")
  @@map("social_handles")
}

model Product {
  id            Int         @id @default(autoincrement())
  institutionId Int         @map("institution_id")
  name          String
  description   String?     @db.Text
  price         Decimal     @db.Decimal(10, 2)
  quantity      Int         @default(0)
  images        String?     @db.LongText
  isVisible     Boolean     @default(true) @map("is_visible")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  orders        Order[]
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId], map: "products_institution_id_fkey")
  @@map("products")
}

model Order {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  productId  Int      @map("product_id")
  quantity   Int      @default(1)
  totalPrice Decimal  @map("total_price") @db.Decimal(10, 2)
  status     String   @default("pending")
  paymentRef String?  @map("payment_ref")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  product         Product          @relation(fields: [productId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  deliveryDetails DeliveryDetails?

  @@index([productId], map: "orders_product_id_fkey")
  @@index([userId], map: "orders_user_id_fkey")
  @@map("orders")
}

model Complaint {
  id            Int         @id @default(autoincrement())
  userId        Int         @map("user_id")
  institutionId Int         @map("institution_id")
  subject       String
  message       String      @db.Text
  status        String      @default("pending")
  forwarded     Boolean     @default(false)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([institutionId], map: "complaints_institution_id_fkey")
  @@index([userId], map: "complaints_user_id_fkey")
  @@map("complaints")
}

model DeliveryDetails {
  id            Int      @id @default(autoincrement())
  orderId       Int      @unique @map("order_id")
  recipientName String   @map("recipient_name")
  phoneNumber   String   @map("phone_number")
  address       String   @db.Text
  latitude      Float?
  longitude     Float?
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("delivery_details")
}

model GeneratedSite {
  id            Int         @id @default(autoincrement())
  institutionId Int         @unique @map("institution_id")
  slug          String      @unique
  status        String      @default("draft")
  themeData     String?     @map("theme_data") @db.LongText
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@map("generated_sites")
}

model AIModel {
  id            Int         @id @default(autoincrement())
  institutionId Int         @map("institution_id")
  provider      String      // 'gemini', 'openai', 'anthropic', etc.
  modelName     String      @map("model_name") // 'gemini-1.5-flash', 'gpt-4', etc.
  apiKey        String      @map("api_key") @db.Text
  isDefault     Boolean     @default(false) @map("is_default")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId], map: "ai_models_institution_id_fkey")
  @@map("ai_models")
}
