generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Institution {
  id                 Int             @id @default(autoincrement())
  name               String
  slug               String          @unique @default("")
  industry           String
  description        String?         @db.Text
  website_url        String?
  logoBase64         String?         @db.LongText @map("logo_base64")
  documents          String?         @db.LongText
  verificationStatus String          @default("pending") @map("verification_status")
  verificationNote   String?         @db.Text @map("verification_note")
  subscription_tier  String          @default("free")
  colorPrimary       String?         @default("#00D4FF") @map("color_primary")
  colorSecondary     String?         @default("#B026FF") @map("color_secondary")
  users              User[]
  brandGuides        BrandGuide[]
  contentSources     ContentSource[]
  agentTasks         AgentTask[]
  generatedPosts     GeneratedPost[]
  socialHandles      SocialHandle[]
  products           Product[]
  generatedSite      GeneratedSite?
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@map("institutions")
}

model BrandGuide {
  id                 Int         @id @default(autoincrement())
  institutionId      Int         @map("institution_id")
  institution        Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  toneVoice          String      @map("tone_voice")
  targetAudience     String      @map("target_audience")
  restrictedKeywords String      @default("[]") @map("restricted_keywords")
  colorPalette       String?     @map("color_palette")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@map("brand_guides")
}

model ContentSource {
  id            Int         @id @default(autoincrement())
  institutionId Int         @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  sourceType    String      @map("source_type")
  sourceUrl     String      @map("source_url")
  lastSynced    DateTime?   @map("last_synced")
  agentTasks    AgentTask[]
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("content_sources")
}

model AgentTask {
  id              Int             @id @default(autoincrement())
  institutionId   Int             @map("institution_id")
  institution     Institution     @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  contentSourceId Int?            @map("content_source_id")
  contentSource   ContentSource?  @relation(fields: [contentSourceId], references: [id], onDelete: SetNull)
  status          String          @default("queued")
  taskType        String          @map("task_type")
  generatedPosts  GeneratedPost[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@map("agent_tasks")
}

model User {
  id            Int          @id @default(autoincrement())
  email         String       @unique
  name          String?
  image         String?
  passwordHash  String?      @map("password_hash")
  institutionId Int?         @map("institution_id")
  institution   Institution? @relation(fields: [institutionId], references: [id])
  role          String       @default("owner")
  orders        Order[]
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("users")
}

model GeneratedPost {
  id            Int         @id @default(autoincrement())
  institutionId Int         @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  agentTaskId   Int         @map("agent_task_id")
  agentTask     AgentTask   @relation(fields: [agentTaskId], references: [id], onDelete: Cascade)
  platform      String
  contentText   String      @map("content_text")
  imageUrl      String?     @map("image_url")
  status        String      @default("pending")
  feedback      String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("generated_posts")
}

model SocialHandle {
  id            Int         @id @default(autoincrement())
  institutionId Int         @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  platform      String
  handle        String
  profileUrl    String?     @map("profile_url")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("social_handles")
}

model Product {
  id            Int         @id @default(autoincrement())
  institutionId Int         @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  description   String?     @db.Text
  price         Decimal     @db.Decimal(10, 2)
  quantity      Int         @default(0)
  images        String?     @db.LongText
  isVisible     Boolean     @default(true) @map("is_visible")
  orders        Order[]
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("products")
}

model Order {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  productId   Int      @map("product_id")
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      @default(1)
  totalPrice  Decimal  @db.Decimal(10, 2) @map("total_price")
  status      String   @default("pending")
  paymentRef  String?  @map("payment_ref")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("orders")
}

model GeneratedSite {
  id            Int         @id @default(autoincrement())
  institutionId Int         @unique @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  slug          String      @unique
  status        String      @default("draft")
  themeData     String?     @db.LongText @map("theme_data")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("generated_sites")
}
